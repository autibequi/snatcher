# =============================================================================
# Promo Snatcher — variáveis de ambiente (deploy Coolify)
# =============================================================================

# === OBRIGATÓRIAS ===

# Senha do painel admin (login em /admin)
AUTH_PASSWORD=

# Chave secreta para assinar tokens JWT
# Gerar: openssl rand -hex 32
AUTH_SECRET=

# API Key do Evolution API — usada pelo backend e pelo Evolution Manager
# Gerar: openssl rand -hex 24
EVOLUTION_API_KEY=

# === INFRAESTRUTURA ===

PUBLIC_URL=https://snatcher.autibequi.com
BASE_DOMAIN=snatcher.autibequi.com

# === OPCIONAIS ===

AUTH_USERNAME=admin
AUTH_TOKEN_HOURS=72
EVOLUTION_INSTANCE=default
EVOLUTION_DB_PASS=evolution
SCAN_INTERVAL=30
TZ_NAME=America/Sao_Paulo

GA_MEASUREMENT_ID=
AMZ_TRACKING_ID=
ML_AFFILIATE_TOOL_ID=
ML_CLIENT_ID=
ML_CLIENT_SECRET=
TG_BOT_TOKEN=
