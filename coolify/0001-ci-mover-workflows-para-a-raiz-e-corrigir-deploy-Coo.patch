+name: Deploy to Coolify
+
+on:
+  workflow_run:
+    workflows: [CI]
+    types: [completed]
+    branches: [main]
+  workflow_dispatch:
+
+concurrency:
+  group: deploy-production
+  cancel-in-progress: true
+
+jobs:
+  deploy:
+    name: Deploy (Coolify)
+    runs-on: ubuntu-latest
+    timeout-minutes: 15
+    environment: production
+    if: >
+      github.event_name == 'workflow_dispatch' ||
+      github.event.workflow_run.conclusion == 'success'
+
+    steps:
+      - name: Trigger Coolify deploy
+        env:
+          COOLIFY_TOKEN: ${{ secrets.COOLIFY_TOKEN }}
+          COOLIFY_WEBHOOK_URL: ${{ secrets.COOLIFY_WEBHOOK_URL }}
+          COOLIFY_UUID: ${{ vars.COOLIFY_RESOURCE_UUID }}
+          COOLIFY_URL: ${{ vars.COOLIFY_URL }}
+        run: |
+          set -euo pipefail
+
+          if [[ -z "${COOLIFY_TOKEN:-}" ]]; then
+            echo "::error::Secret COOLIFY_TOKEN não configurado (Settings → Secrets → Actions)"
+            exit 1
+          fi
+
+          COOLIFY_URL="${COOLIFY_URL:-https://coolify.autibequi.com}"
+
+          if [[ -n "${COOLIFY_WEBHOOK_URL:-}" ]]; then
+            target="${COOLIFY_WEBHOOK_URL}"
+          elif [[ -n "${COOLIFY_UUID:-}" ]]; then
+            target="${COOLIFY_URL}/api/v1/deploy?uuid=${COOLIFY_UUID}&force=false"
+          else
+            echo "::error::Configure COOLIFY_WEBHOOK_URL (secret) ou COOLIFY_RESOURCE_UUID (variable no environment production)"
+            exit 1
+          fi
+
+          echo "POST ${target}"
+
+          response=$(curl -sS -w "\n%{http_code}" \
+            -X POST \
+            -H "Authorization: Bearer ${COOLIFY_TOKEN}" \
+            -H "Content-Type: application/json" \
+            "${target}")
+
+          http_code=$(echo "$response" | tail -n1)
+          body=$(echo "$response" | head -n -1)
+          echo "HTTP ${http_code} — ${body}"
+
+          case "${http_code}" in
+            200|201|202|204) echo "Deploy enfileirado." ;;
+            *) echo "::error::Deploy falhou — HTTP ${http_code}"; exit 1 ;;
+          esac
+
+      - name: Health check
+        env:
+          APP_URL: ${{ vars.APP_URL }}
+        run: |
+          APP_URL="${APP_URL:-https://snatcher.autibequi.com}"
+          sleep 120
+          for i in 1 2 3 4 5; do
+            status=$(curl -sS -o /dev/null -w "%{http_code}" "${APP_URL}/api/health" || echo "000")
+            if [ "$status" = "200" ]; then
+              echo "OK — ${APP_URL}"
+              exit 0
+            fi
+            echo "Tentativa ${i}/5 — HTTP ${status}"
+            sleep 30
+          done
+          echo "::warning::Health check falhou — ver logs no Coolify"
